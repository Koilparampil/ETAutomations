# Copy this file to .env and fill in your values.
# .env is excluded from git — never commit real credentials.

QB_CLIENT_ID=your_client_id_here
QB_CLIENT_SECRET=your_client_secret_here
QB_REFRESH_TOKEN=your_refresh_token_here
QB_REALM_ID=your_company_id_here   # the numeric ID in your QBO URL

# Set to "true" to hit the sandbox environment instead of production
QB_SANDBOX=false
