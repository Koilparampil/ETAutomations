# Copy this file to .env and fill in your values.
# .env is excluded from git — never commit real credentials.

QB_CLIENT_ID=your_client_id_here
QB_CLIENT_SECRET=your_client_secret_here
QB_REFRESH_TOKEN=your_refresh_token_here
QB_REALM_ID=your_company_id_here   # the numeric ID in your QBO URL

# Set to "true" to hit the sandbox environment instead of production
QB_SANDBOX=false

# DefinitionId for the "ETA" User Defined Custom Field (UDCF).
# QBO's Preferences API does not list UDCFs, so set this manually.
# Find it in Chrome DevTools → Network → any invoice request → look for the
# ETA definition object and copy the long numeric ID at the end of its "id" field.
# Example from DevTools:  "id": "...CustomFieldDefinition:20000000000000150677"
#                                                            ^^^^^^^^^^^^^^^^^^^^^ use this part
QB_ETA_DEFINITION_ID=20000000000000150677
